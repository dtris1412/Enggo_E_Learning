DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASS=
# Server Configuration
PORT=8080
NODE_ENV=development

# JWT Secret Keys
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# Frontend URL for social login redirect
FRONTEND_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:8080/api/auth/facebook/callback

# OPEN AI API KEY
OPENAI_API_KEY=

# Redis Cache (optional - falls back to in-memory if not set)
# Để trống nếu không dùng Redis (sẽ tự động dùng in-memory cache)
# Docker local: redis://localhost:6379
# Production:   redis://:password@host:6379
REDIS_URL=
REDIS_AI_CACHE_TTL=604800

# ============ EMAIL - BREVO ============
# Lấy API key từ: https://app.brevo.com/settings/keys/api
# Brevo free tier: 300 emails/day
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@enggo.com
BREVO_SENDER_NAME=Enggo Learning